{
  "name": "@salamruby/cache",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "homepage": "https://salamruby.com",
  "description": "Unified Redis cache for SalamRuby",
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/salamruby/salamruby"
  },
  "keywords": [
    "SalamRuby",
    "cache",
    "redis",
    "caching"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "types": "./dist/src/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "clean": "rimraf .turbo node_modules coverage dist",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "lint:report": "eslint . --format json --output-file ../../lint-results/cache.json",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "go": "vite build --watch --mode dev"
  },
  "author": "SalamRuby <hola@salamruby.com>",
  "dependencies": {
    "@salamruby/logger": "workspace:*",
    "redis": "5.11.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@salamruby/config-typescript": "workspace:*",
    "@salamruby/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "4.1.6",
    "vite": "7.3.3",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.6"
  }
}
