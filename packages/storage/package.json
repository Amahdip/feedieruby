{
  "name": "@salamruby/storage",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "homepage": "https://salamruby.com",
  "description": "Storage Controller for SalamRuby",
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/salamruby/salamruby"
  },
  "keywords": [
    "SalamRuby",
    "storage",
    "storage controller"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "types": "./dist/src/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "clean": "rimraf .turbo node_modules coverage dist",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "lint:report": "eslint . --format json --output-file ../../lint-results/app-store.json",
    "typecheck": "tsc --noEmit",
    "build": "vite build && tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "go": "vite build --watch --mode dev"
  },
  "author": "SalamRuby <hola@salamruby.com>",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1007.0",
    "@aws-sdk/s3-presigned-post": "3.1007.0",
    "@aws-sdk/s3-request-presigner": "3.1007.0",
    "@salamruby/logger": "workspace:*"
  },
  "devDependencies": {
    "@salamruby/config-typescript": "workspace:*",
    "@salamruby/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "4.1.6",
    "vite": "7.3.3",
    "vitest": "4.1.6"
  }
}
