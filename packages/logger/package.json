{
  "name": "@salamruby/logger",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "homepage": "https://salamruby.com",
  "license": "MIT",
  "description": "Logger for SalamRuby",
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/salamruby/salamruby"
  },
  "keywords": [
    "SalamRuby",
    "logger",
    "logging"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "types": "./dist/src/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "clean": "rimraf .turbo node_modules coverage dist",
    "lint": "eslint . --ext .ts,.js,.tsx,.jsx",
    "lint:fix": "eslint . --ext .ts,.js,.tsx,.jsx --fix",
    "lint:report": "eslint . --format json --output-file ../../lint-results/app-store.json",
    "typecheck": "tsc --noEmit",
    "build": "rimraf dist && vite build && tsc --project tsconfig.build.json",
    "test": "vitest run"
  },
  "author": "SalamRuby <hola@salamruby.com>",
  "dependencies": {
    "pino": "10.3.1",
    "pino-opentelemetry-transport": "3.0.0",
    "pino-pretty": "13.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@salamruby/config-typescript": "workspace:*",
    "@salamruby/eslint-config": "workspace:*",
    "vite": "7.3.3",
    "vitest": "4.1.6"
  }
}
