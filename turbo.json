{
  "$schema": "https://turborepo.org/schema.json",
  "globalEnv": ["MIGRATE_DATABASE_URL", "SHADOW_DATABASE_URL"],
  "tasks": {
    "@salamruby/ai#build": {
      "dependsOn": ["@salamruby/logger#build"],
      "outputs": ["dist/**"]
    },
    "@salamruby/ai#lint": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/ai#test": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/ai#test:coverage": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/ai#typecheck": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/cache#build": {
      "dependsOn": ["@salamruby/logger#build"],
      "outputs": ["dist/**"]
    },
    "@salamruby/cache#go": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/cache#lint": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/cache#test": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/cache#test:coverage": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/cache#typecheck": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/database#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "generated/prisma/**"]
    },
    "@salamruby/database#lint": {
      "dependsOn": ["@salamruby/logger#build", "@salamruby/database#build"]
    },
    "@salamruby/database#typecheck": {
      "dependsOn": ["@salamruby/logger#build", "@salamruby/database#generate"]
    },
    "@salamruby/email#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@salamruby/i18n-utils#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@salamruby/i18n-utils#lint": {
      "dependsOn": ["^lint"]
    },
    "@salamruby/i18n-utils#test": {
      "dependsOn": ["@salamruby/i18n-utils#build"]
    },
    "@salamruby/jobs#build": {
      "dependsOn": ["@salamruby/logger#build"],
      "outputs": ["dist/**"]
    },
    "@salamruby/jobs#lint": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/jobs#test": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/jobs#test:coverage": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/js-core#build": {
      "dependsOn": ["^build", "@salamruby/database#build"],
      "outputs": ["dist/**"]
    },
    "@salamruby/js-core#go": {
      "cache": false,
      "dependsOn": ["@salamruby/database#db:setup"],
      "persistent": true
    },
    "@salamruby/js-core#lint": {
      "dependsOn": ["@salamruby/database#build"]
    },
    "@salamruby/js-core#typecheck": {
      "dependsOn": ["@salamruby/database#build"]
    },
    "@salamruby/logger#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@salamruby/storage#build": {
      "dependsOn": ["@salamruby/logger#build"],
      "outputs": ["dist/**"]
    },
    "@salamruby/storage#go": {
      "cache": false,
      "dependsOn": ["@salamruby/storage#build"],
      "persistent": true
    },
    "@salamruby/storage#lint": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/storage#test": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/storage#test:coverage": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/storage#typecheck": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "@salamruby/survey-ui#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@salamruby/survey-ui#build:dev": {
      "dependsOn": ["^build:dev"],
      "outputs": ["dist/**"]
    },
    "@salamruby/survey-ui#go": {
      "cache": false,
      "dependsOn": ["@salamruby/survey-ui#build"],
      "persistent": true
    },
    "@salamruby/surveys#build": {
      "dependsOn": ["^build", "@salamruby/survey-ui#build"],
      "outputs": ["dist/**"]
    },
    "@salamruby/surveys#build:dev": {
      "dependsOn": ["^build:dev", "@salamruby/i18n-utils#build", "@salamruby/survey-ui#build:dev"],
      "outputs": ["dist/**"]
    },
    "@salamruby/surveys#go": {
      "cache": false,
      "dependsOn": ["@salamruby/survey-ui#build", "@salamruby/surveys#build"],
      "persistent": true
    },
    "@salamruby/surveys#test": {
      "dependsOn": ["@salamruby/survey-ui#build"]
    },
    "@salamruby/surveys#test:coverage": {
      "dependsOn": ["@salamruby/survey-ui#build"]
    },
    "@salamruby/surveys#typecheck": {
      "dependsOn": ["@salamruby/i18n-utils#build", "@salamruby/survey-ui#build"]
    },
    "@salamruby/web#dev": {
      "cache": false,
      "dependsOn": [
        "@salamruby/ai#build",
        "@salamruby/cache#build",
        "@salamruby/database#build",
        "@salamruby/jobs#build",
        "@salamruby/logger#build",
        "@salamruby/storage#build"
      ],
      "persistent": true
    },
    "@salamruby/web#go": {
      "cache": false,
      "dependsOn": [
        "@salamruby/ai#build",
        "@salamruby/cache#build",
        "@salamruby/database#build",
        "@salamruby/database#db:setup",
        "@salamruby/jobs#build",
        "@salamruby/logger#build",
        "@salamruby/storage#build"
      ],
      "persistent": true
    },
    "@salamruby/web#test": {
      "dependsOn": [
        "@salamruby/ai#build",
        "@salamruby/logger#build",
        "@salamruby/database#build",
        "@salamruby/storage#build",
        "@salamruby/cache#build",
        "@salamruby/jobs#build",
        "@salamruby/surveys#build"
      ]
    },
    "@salamruby/web#test:coverage": {
      "dependsOn": [
        "@salamruby/ai#build",
        "@salamruby/logger#build",
        "@salamruby/database#build",
        "@salamruby/storage#build",
        "@salamruby/cache#build",
        "@salamruby/jobs#build",
        "@salamruby/surveys#build"
      ]
    },
    "@salamruby/web#typecheck": {
      "dependsOn": [
        "@salamruby/ai#build",
        "@salamruby/cache#build",
        "@salamruby/database#build",
        "@salamruby/logger#build",
        "@salamruby/storage#build",
        "@salamruby/surveys#build"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "AUDIT_LOG_ENABLED",
        "AUDIT_LOG_GET_USER_IP",
        "AI_AWS_ACCESS_KEY_ID",
        "AI_AWS_REGION",
        "AI_AWS_SECRET_ACCESS_KEY",
        "AI_AWS_SESSION_TOKEN",
        "AI_AZURE_API_KEY",
        "AI_AZURE_API_VERSION",
        "AI_AZURE_BASE_URL",
        "AI_AZURE_RESOURCE_NAME",
        "AI_GOOGLE_CLOUD_APPLICATION_CREDENTIALS",
        "AI_GOOGLE_CLOUD_CREDENTIALS_JSON",
        "AI_GOOGLE_CLOUD_LOCATION",
        "AI_GOOGLE_CLOUD_PROJECT",
        "AI_MODEL",
        "AI_OPENAI_COMPATIBLE_API_KEY",
        "AI_OPENAI_COMPATIBLE_BASE_URL",
        "AI_OPENAI_COMPATIBLE_HEADERS_JSON",
        "AI_OPENAI_COMPATIBLE_PROVIDER_NAME",
        "AI_OPENAI_COMPATIBLE_QUERY_PARAMS_JSON",
        "AI_OPENAI_COMPATIBLE_SUPPORTS_STRUCTURED_OUTPUTS",
        "AI_PROVIDER",
        "AIRTABLE_CLIENT_ID",
        "ASSET_PREFIX_URL",
        "AZUREAD_CLIENT_ID",
        "AZUREAD_CLIENT_SECRET",
        "AZUREAD_TENANT_ID",
        "AUTH_SSO_DEFAULT_TEAM_ID",
        "AUTH_SKIP_INVITE_FOR_SSO",
        "BULLMQ_EXTERNAL_WORKER_ENABLED",
        "BULLMQ_WORKER_CONCURRENCY",
        "BULLMQ_WORKER_COUNT",
        "BULLMQ_WORKER_ENABLED",
        "BASE_PATH",
        "BREVO_API_KEY",
        "BREVO_LIST_ID",
        "CRON_SECRET",
        "CUBEJS_API_SECRET",
        "CUBEJS_API_URL",
        "CUBEJS_JWT_AUDIENCE",
        "CUBEJS_JWT_ISSUER",
        "DISABLE_ACCOUNT_DELETION_SSO_CONFIRMATION",
        "DANGEROUSLY_ALLOW_WEBHOOK_INTERNAL_URLS",
        "DATABASE_URL",
        "DEBUG",
        "DEBUG_SHOW_RESET_LINK",
        "E2E_TESTING",
        "EMAIL_AUTH_DISABLED",
        "EMAIL_VERIFICATION_DISABLED",
        "ENCRYPTION_KEY",
        "ENTERPRISE_LICENSE_KEY",
        "ENVIRONMENT",
        "GITHUB_ID",
        "GITHUB_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_SHEETS_CLIENT_ID",
        "GOOGLE_SHEETS_CLIENT_SECRET",
        "GOOGLE_SHEETS_REDIRECT_URL",
        "HUB_API_KEY",
        "HUB_API_URL",
        "NOTION_OAUTH_CLIENT_ID",
        "NOTION_OAUTH_CLIENT_SECRET",
        "HEROKU_APP_NAME",
        "HTTP_PROXY",
        "HTTPS_PROXY",
        "IMPRINT_URL",
        "IMPRINT_ADDRESS",
        "INVITE_DISABLED",
        "IS_SALAMRUBY_CLOUD",
        "CHATWOOT_WEBSITE_TOKEN",
        "CHATWOOT_BASE_URL",
        "POSTHOG_KEY",
        "LOG_LEVEL",
        "MAIL_FROM",
        "MAIL_FROM_NAME",
        "NEXT_PUBLIC_LAYER_API_KEY",
        "NEXT_PUBLIC_DOCSEARCH_APP_ID",
        "NEXT_PUBLIC_DOCSEARCH_API_KEY",
        "NEXT_PUBLIC_DOCSEARCH_INDEX_NAME",
        "NEXT_PUBLIC_SALAMRUBY_PMF_FORM_ID",
        "NEXT_PUBLIC_SALAMRUBY_URL",
        "NEXT_PUBLIC_SALAMRUBY_COM_API_HOST",
        "NEXT_PUBLIC_SALAMRUBY_COM_ENVIRONMENT_ID",
        "NEXT_PUBLIC_SALAMRUBY_COM_DOCS_FEEDBACK_SURVEY_ID",
        "OPENAI_API_KEY",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_HEADERS",
        "OTEL_EXPORTER_OTLP_PROTOCOL",
        "OTEL_RESOURCE_ATTRIBUTES",
        "OTEL_SERVICE_NAME",
        "OTEL_TRACES_SAMPLER",
        "OTEL_TRACES_SAMPLER_ARG",
        "NEXT_RUNTIME",
        "NEXTAUTH_SECRET",
        "NEXTAUTH_URL",
        "NODE_ENV",
        "npm_package_version",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_DISPLAY_NAME",
        "OIDC_ISSUER",
        "OIDC_SIGNING_ALGORITHM",
        "PASSWORD_RESET_DISABLED",
        "PASSWORD_RESET_TOKEN_LIFETIME_MINUTES",
        "PLAYWRIGHT_CI",
        "PRIVACY_URL",
        "RATE_LIMITING_DISABLED",
        "REDIS_URL",
        "S3_ACCESS_KEY",
        "S3_BUCKET_NAME",
        "S3_ENDPOINT_URL",
        "S3_FORCE_PATH_STYLE",
        "S3_REGION",
        "S3_SECRET_KEY",
        "SAML_DATABASE_URL",
        "SESSION_MAX_AGE",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_DSN",
        "SENTRY_ENVIRONMENT",
        "SLACK_CLIENT_ID",
        "SLACK_CLIENT_SECRET",
        "SMTP_HOST",
        "SMTP_PASSWORD",
        "SMTP_PORT",
        "SMTP_SECURE_ENABLED",
        "SMTP_USER",
        "SMTP_REJECT_UNAUTHORIZED_TLS",
        "SMTP_AUTHENTICATED",
        "STRAPI_API_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "STRIPE_PUBLISHABLE_KEY",
        "SURVEYS_PACKAGE_MODE",
        "SURVEYS_PACKAGE_BUILD",
        "PUBLIC_URL",
        "TURNSTILE_SECRET_KEY",
        "TURNSTILE_SITE_KEY",
        "RECAPTCHA_SITE_KEY",
        "RECAPTCHA_SECRET_KEY",
        "TELEMETRY_DISABLED",
        "TERMS_URL",
        "VERSION",
        "WEBAPP_URL",
        "UNSPLASH_ACCESS_KEY",
        "PROMETHEUS_ENABLED",
        "PROMETHEUS_EXPORTER_PORT",
        "USER_MANAGEMENT_MINIMUM_ROLE"
      ],
      "outputs": ["dist/**", ".next/**"]
    },
    "build:dev": {
      "dependsOn": ["^build:dev"],
      "outputs": ["dist/**", ".next/**"]
    },
    "clean": {
      "cache": false,
      "outputs": []
    },
    "db:down": {
      "cache": false,
      "outputs": []
    },
    "db:migrate:deploy": {
      "cache": false,
      "outputs": []
    },
    "db:migrate:dev": {
      "cache": false,
      "outputs": []
    },
    "db:push": {
      "outputs": []
    },
    "db:seed": {
      "env": ["ALLOW_SEED"],
      "outputs": []
    },
    "db:setup": {
      "cache": false,
      "dependsOn": ["@salamruby/logger#build", "@salamruby/database#build"],
      "outputs": []
    },
    "db:start": {
      "cache": false
    },
    "db:up": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate": {
      "dependsOn": ["^generate"]
    },
    "go": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "start": {
      "outputs": []
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "storybook#storybook": {
      "dependsOn": ["@salamruby/logger#build"]
    },
    "test": {
      "outputs": []
    },
    "test:coverage": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["@salamruby/database#generate", "^typecheck"],
      "outputs": []
    }
  },
  "ui": "stream"
}
